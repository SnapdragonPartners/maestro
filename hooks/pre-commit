#!/bin/bash

# Pre-commit check script for maestro
# Ensures build passes and all linting issues are resolved

set -e

echo "🔨 Pre-commit checks for maestro..."

# 0. Stamp edit_date on staged docs (ADR 0017). Runs first so the stamped
# files are part of this commit. Never blocks: a stale date is a nit, a hook
# that refuses to commit is a work stopper.
echo "0. Stamping doc edit_date..."
# Resolve the repo root explicitly: git normally runs hooks from the worktree
# top level, but that is not guaranteed for every invocation path, and a
# silently-skipped stamp is the failure this hook exists to prevent.
REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
if [ -n "$REPO_ROOT" ] && [ -x "$REPO_ROOT/scripts/stamp-edit-date.sh" ]; then
    "$REPO_ROOT/scripts/stamp-edit-date.sh" || true
fi

# 1. Ensure build passes
echo "1. Checking build..."
if ! make build >/dev/null 2>&1; then
    echo "❌ Build failed! Fix build errors before committing."
    exit 1
fi
echo "✅ Build passed"

# 2. Run core tests (with timeout)
echo "2. Running core tests..."
if ! go test -cover -timeout=300s ./... >/dev/null 2>&1; then
    echo "⚠️  Tests timed out or failed. Consider running 'make test' manually."
    exit 1
fi
echo "✅ Tests completed"

# 3. Run comprehensive linting
echo "3. Running comprehensive linting..."
set +e
LINT_OUTPUT=$(make lint 2>&1)
LINT_EXIT_CODE=$?
set -e

if [ $LINT_EXIT_CODE -ne 0 ]; then
    echo "❌ BLOCKING: Linting issues found. All lint errors must be resolved before committing."
    echo ""
    echo "Lint output:"
    echo "$LINT_OUTPUT"
    echo ""
    echo "💡 Run 'make lint' to see all issues, then fix them before committing."
    exit 1
fi

echo "✅ All linting checks passed!"
echo "✅ Pre-commit checks completed successfully!"
exit 0
